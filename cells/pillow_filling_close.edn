;; makura 枕 — pillow_filling_close cell
{:cell/id          "pillow_filling_close"
 :cell/glyph       "☁️"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "Fill pillow shell with crumb stream and close."
 :cell/gates       [{:gate/id "G12" :gate/name "bom-disclosure"} {:gate/id "G13" :gate/name "ipfs-pinned-take-back-qr"}]
 :cell/llm         {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/kotoba      {:reads    []
                    :writes   []}
 :cell/state-graph {:nodes [{:id "start" :type "llm-prompt" :prompt "Collect empty shell and crumb stream."}
                           {:id "record_pillow_lot" :type "function" :func "record_pillow_lot"}
                           {:id "end" :type "return"}]
                    :entry    "start"
                    :edges    [{:from "start" :to "record_pillow_lot"}
                               {:from "record_pillow_lot" :to "end"}]}}
