;; makura 枕 — pillow_isocyanate_dispensing cell
{:cell/id          "pillow_isocyanate_dispensing"
 :cell/glyph       "⚠️"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "Dispense isocyanate and record worker exposure."
 :cell/gates       [{:gate/id "G6" :gate/name "closed-loop-isocyanate-handling"}]
