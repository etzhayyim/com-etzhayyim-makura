;; makura 枕 — pillow_polyol_attestation cell
{:cell/id          "pillow_polyol_attestation"
 :cell/glyph       "🧪"
 :cell/kind        :langgraph
 :cell/runtime     :wasm
 :cell/doc         "Attest polyol, catalyst, and surfactant lots for foam production."
 :cell/gates       [{:gate/id "G1" :gate/name "open-source-firmware-recipes"}]
 :cell/llm         {:provider :murakumo :endpoint "127.0.0.1:4000" :model "gemma3:4b" :charter-rider true}
 :cell/kotoba      {:reads    []
                    :writes   []}
 :cell/state-graph {:nodes [{:id "start" :type "llm-prompt" :prompt "Collect polyol, catalyst, surfactant lot details."}
                           {:id "validate" :type "function" :func "validate_polyol_attestation"}
                           {:id "end" :type "return"}]
                    :entry    "start"
                    :edges    [{:from "start" :to "validate"}
                               {:from "validate" :to "end"}]}}
